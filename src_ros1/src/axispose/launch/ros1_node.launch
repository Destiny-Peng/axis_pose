<launch>
  <arg name="use_mock_driver" default="false" />
  <arg name="run_visualization" default="true" />
  <arg name="run_segmentation" default="true" />
  <arg name="pose_algorithm" default="pca" />
  <arg name="statistics_dir" default="/tmp/axispose_runtime" />
  <arg name="enable_preload" default="true" />

  <arg name="color_topic" default="/camera/color/image_raw" />
  <arg name="depth_topic" default="/camera/aligned_depth_to_color/image_raw" />
  <arg name="color_camera_info_topic" default="/camera/color/camera_info" />
  <arg name="depth_camera_info_topic" default="/camera/depth/camera_info" />

  <!-- Optional mock image driver for offline replay. Disabled by default on real hardware. -->
  <node if="$(arg use_mock_driver)" pkg="axispose" type="camera_driver_node" name="camera_driver" output="screen">
    <param name="rgb_dir" value="$(find axispose)/image/rgb" />
    <param name="depth_dir" value="$(find axispose)/image/depth" />
    <param name="camera_info_file" value="$(find axispose)/config/camera_info.yaml" />
    <param name="frame_id" value="camera" />
    <param name="publish_rate" value="8.0" />
    <param name="loop" value="true" />
  </node>

  <node if="$(eval arg('run_segmentation') and arg('enable_preload'))" pkg="axispose" type="segment_node" name="segment_node" output="screen">
    <env name="LD_PRELOAD" value="/usr/local/lib/libcustom_plugins.so" />
    <param name="engine" value="$(find axispose)/engine/best.engine" />
    <param name="image_topic" value="$(arg color_topic)" />
  </node>

  <node if="$(eval arg('run_segmentation') and not arg('enable_preload'))" pkg="axispose" type="segment_node" name="segment_node" output="screen">
    <param name="engine" value="$(find axispose)/engine/best.engine" />
    <param name="image_topic" value="$(arg color_topic)" />
  </node>

  <node pkg="axispose" type="pose_estimate_node" name="pose_estimate" output="screen">
    <param name="algorithm_type" value="$(arg pose_algorithm)" />
    <param name="statistics_directory_path" value="$(arg statistics_dir)/$(arg pose_algorithm)" />
    <param name="statistics_enabled" value="true" />
    <param name="voxel_leaf_size" value="0.05" />
    <param name="sor_mean_k" value="50" />
    <param name="sor_std_mul" value="1.0" />
    <param name="use_sor" value="true" />
    <param name="use_euclidean_cluster" value="true" />
    <param name="cluster_mode" value="0" />
    <param name="sacline_distance_threshold" value="0.05" />
    <param name="align_depth_to_color" value="false" />
    <param name="depth_topic" value="$(arg depth_topic)" />
    <param name="mask_topic" value="/yolo/mask" />
    <param name="color_camera_info_topic" value="$(arg color_camera_info_topic)" />
    <param name="depth_camera_info_topic" value="$(arg depth_camera_info_topic)" />
  </node>

  <node if="$(arg run_visualization)" pkg="axispose" type="visualization_node" name="visualization" output="screen">
    <param name="rgb_topic" value="$(arg color_topic)" />
    <param name="camera_info_topic" value="$(arg color_camera_info_topic)" />
    <param name="mask_topic" value="/yolo/mask" />
    <param name="pose_topic" value="/shaft/pose" />
    <param name="axis_length" value="0.25" />
  </node>

</launch>
