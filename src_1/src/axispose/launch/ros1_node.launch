<launch>
  <!-- Camera driver -->
  <node pkg="axispose" type="camera_driver_node" name="camera_driver" output="screen">
    <param name="rgb_dir" value="$(find axispose)/image/rgb" />
    <param name="depth_dir" value="$(find axispose)/image/depth" />
    <param name="camera_info_file" value="$(find axispose)/config/camera_info.yaml" />
    <param name="frame_id" value="camera" />
    <param name="publish_rate" value="1.0" />
    <param name="loop" value="true" />
  </node>

  <!-- Segment node -->
  <node pkg="axispose" type="segment_node" name="segment_node" output="screen">
    <env name="LD_PRELOAD" value="/usr/local/lib/libcustom_plugins.so" />
    <param name="engine" value="$(find axispose)/engine/best.engine" />
    <param name="image_topic" value="/camera/rgb/image_raw" />
  </node>

  <!-- Pose estimate -->
  <node pkg="axispose" type="pose_estimate_node" name="pose_estimate" output="screen">
    <param name="voxel_leaf_size" value="0.1" />
    <param name="sor_mean_k" value="50" />
    <param name="sor_std_mul" value="1.0" />
    <param name="depth_topic" value="/camera/depth/image_raw" />
    <param name="mask_topic" value="/yolo/mask" />
    <param name="camera_info_topic" value="/camera/camera_info" />
  </node>

  <!-- Visualization -->
  <node pkg="axispose" type="visualization_node" name="visualization" output="screen"/>

</launch>
